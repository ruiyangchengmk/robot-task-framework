{
  "task_id": "greet_guest_001",
  "description": "去门口迎接客人",
  "robot": "Unitree G1",
  "actions": [
    {
      "id": 1,
      "atomic": "locate",
      "params": {"target": "guest"},
      "timeout": 10
    },
    {
      "id": 2,
      "atomic": "walk_to",
      "params": {"x": 2.0, "y": 0.0, "theta": 0},
      "depends_on": [1],
      "timeout": 30
    },
    {
      "id": 3,
      "atomic": "look_at",
      "params": {"target": "guest"},
      "depends_on": [2],
      "timeout": 5
    },
    {
      "id": 4,
      "atomic": "speak",
      "params": {"text": "你好，欢迎光临！", "emotion": "happy"},
      "depends_on": [3],
      "timeout": 10
    }
  ]
}
