{
  "task_id": "bring_water_001",
  "description": "去茶几拿水杯给我",
  "robot": "Unitree G1",
  "actions": [
    {
      "id": 1,
      "atomic": "locate",
      "params": {"target": "水杯"},
      "timeout": 10
    },
    {
      "id": 2,
      "atomic": "walk_to",
      "params": {"x": 1.5, "y": 0.8, "theta": 0},
      "depends_on": [1],
      "timeout": 30
    },
    {
      "id": 3,
      "atomic": "look_at",
      "params": {"target": "水杯"},
      "depends_on": [2],
      "timeout": 5
    },
    {
      "id": 4,
      "atomic": "grasp",
      "params": {"object_id": "cup_001", "hand": "right"},
      "depends_on": [3],
      "timeout": 15
    },
    {
      "id": 5,
      "atomic": "walk_to",
      "params": {"x": 0.0, "y": 0.0, "theta": 180},
      "depends_on": [4],
      "timeout": 30
    },
    {
      "id": 6,
      "atomic": "handover",
      "params": {"hand": "right"},
      "depends_on": [5],
      "timeout": 10
    }
  ]
}
